sudo -E python3 ground/bin/setup_db.py

sudo mysql -u root -p -e "ALTER USER 'daq'@'127.0.0.1' IDENTIFIED WITH mysql_native_password BY 'tof_monitor_secure'; ALTER USER 'daq'@'localhost' IDENTIFIED WITH mysql_native_password BY 'tof_monitor_secure'; FLUSH PRIVILEGES;"

python3 -u $TOF_BRIDGE_SCRIPT 2>&1 | ts '[%Y-%m-%d %H:%M:%S]' | tee -a $TOFDATA/ground_bridge.log

(Create new table)
mysql -u daq -p -e "DROP TABLE IF EXISTS grams.tof_monitor;"
mysql -u daq -p < $GLIB/ground/sql/create_tof_monitor.sql

(Wipe the current data)
mysql -u daq -p -e "TRUNCATE TABLE grams.tof_monitor;"

(Check)
mysql -u daq -p -e "SELECT * FROM grams.tof_monitor;"
mysql -u daq -p -e "SELECT hname, n_bins_x, x_min, x_max, n_bins_y, y_min, y_max FROM grams.tof_monitor WHERE bin_index = 0;"
